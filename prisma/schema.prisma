generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model application_status_history {
  id             String             @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  application_id String             @db.Uuid
  status         application_status
  changed_at     DateTime?          @default(now()) @db.Timestamptz(6)
  applications   applications       @relation(fields: [application_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_application")

  @@index([application_id], map: "idx_status_history_application")
}

model applications {
  id                         String                       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id                    String                       @db.Uuid
  internship_id              String                       @db.Uuid
  current_status             application_status?          @default(Applied)
  interview_date             DateTime?                    @db.Timestamptz(6)
  salary_offer               Decimal?                     @db.Decimal(10, 2)
  confidence_score           Int?
  priority_level             Int?
  ai_match_score             Int?
  time_to_response           Unsupported("interval")?
  ai_analysis                Json?
  applied_at                 DateTime?                    @default(now()) @db.Timestamptz(6)
  updated_at                 DateTime?                    @default(now()) @db.Timestamptz(6)
  application_status_history application_status_history[]
  internships                internships                  @relation(fields: [internship_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_internship")
  users                      users                        @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_user")
  documents                  documents[]
  notes                      notes[]
  reminders                  reminders[]

  @@index([internship_id], map: "idx_applications_internship")
  @@index([user_id], map: "idx_applications_user")
}

model companies {
  id          String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name        String
  industry    String?
  location    String?
  website     String?
  metadata    Json?
  created_at  DateTime?     @default(now()) @db.Timestamptz(6)
  internships internships[]
}

model documents {
  id             String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  application_id String       @db.Uuid
  user_id        String       @db.Uuid
  file_name      String
  file_url       String
  document_type  String?
  uploaded_at    DateTime?    @default(now()) @db.Timestamptz(6)
  applications   applications @relation(fields: [application_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_application_document")
  users          users        @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_user_document")

  @@index([application_id], map: "idx_documents_application")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model internships {
  id              String                   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id      String                   @db.Uuid
  title           String
  description     String?
  location        String?
  location_point  String?
  type            String?
  stipend         Decimal?                 @db.Decimal(10, 2)
  required_skills String[]
  search_vector   Unsupported("tsvector")?
  posted_at       DateTime?                @default(now()) @db.Timestamptz(6)
  applications    applications[]
  companies       companies                @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_company")

  @@index([search_vector], map: "idx_internships_search", type: Gin)
}

model notes {
  id             String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  application_id String       @db.Uuid
  content        String
  created_at     DateTime?    @default(now()) @db.Timestamptz(6)
  applications   applications @relation(fields: [application_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_application_note")

  @@index([application_id], map: "idx_notes_application")
}

model reminders {
  id             String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id        String        @db.Uuid
  application_id String?       @db.Uuid
  title          String
  description    String?
  reminder_date  DateTime      @db.Timestamptz(6)
  is_completed   Boolean?      @default(false)
  applications   applications? @relation(fields: [application_id], references: [id], onUpdate: NoAction, map: "fk_application_reminder")
  users          users         @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_user_reminder")

  @@index([user_id], map: "idx_reminders_user")
}

model users {
  id            String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name          String
  email         String         @unique @db.Citext
  password_hash String
  user_skills   String[]
  created_at    DateTime?      @default(now()) @db.Timestamptz(6)
  updated_at    DateTime?      @default(now()) @db.Timestamptz(6)
  applications  applications[]
  documents     documents[]
  reminders     reminders[]
}

enum application_status {
  Applied
  Screening
  Interview
  Offer
  Rejected
  Accepted
}
